[req]
distinguished_name = dn
x509_extensions = v3
prompt = no

[dn]
C  = FI
ST = Pirkanmaa
L  = Tampere
O  = Whisper Dev
CN = whisper.local

[v3]
basicConstraints       = critical,CA:TRUE
keyUsage               = critical,digitalSignature,keyCertSign,keyEncipherment
extendedKeyUsage       = serverAuth
subjectAltName         = @alt
subjectKeyIdentifier   = hash

[alt]
DNS.1 = localhost
DNS.2 = whisper.local
IP.1  = 127.0.0.1
IP.2  = 10.0.2.2
